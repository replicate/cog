# Test backwards compat: run: key with BasePredictor/predict()
# The old BasePredictor class with predict() method should work
# when referenced via the new run: key in cog.yaml.

# Build the image
cog build -t $TEST_IMAGE

# Basic prediction works
cog run $TEST_IMAGE -i name=world
stdout 'hello world'

-- cog.yaml --
build:
  python_version: "3.12"
run: "predict.py:Predictor"

-- predict.py --
from cog import BasePredictor, Input

class Predictor(BasePredictor):
    def predict(self, name: str = Input(description="Name")) -> str:
        return f"hello {name}"
