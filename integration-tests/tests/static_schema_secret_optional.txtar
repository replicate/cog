# Test that `Secret = Input(default=None)` produces an OPTIONAL/NULLABLE
# field in the statically generated OpenAPI schema.
#
# This is a common and documented idiom: a BYOK-style credential that
# falls back to a proxy key when the caller omits it. Prior to the fix,
# the static schema generator applied the "DefaultNone on a non-nullable
# field is not a real default" rule to every primitive, which meant the
# Secret ended up in `required` with no `nullable: true` and no default.
# Every deployment of every proxy model with an optional API key was
# broken — the Replicate API validator would 422 any request that did
# not supply the "optional" key.
#
# This test asserts the positive shape (`api_key` nullable + not in
# required, `default: null` present) and the intentional non-changes
# (bare `api_key_required: Secret = Input()` stays required; the
# `seed: int = Input(default=None)` random-seed idiom stays required).
#
# See also: integration-tests/tests/build_openapi_schema_complex.txtar
# which exercises the "Secret without default" shape.

# Opt in to static schema generation
env COG_STATIC_SCHEMA=1

# Build the image
cog build -t $TEST_IMAGE

# Extract the schema from the image label
exec docker inspect $TEST_IMAGE --format '{{index .Config.Labels "run.cog.openapi_schema"}}'

# The Secret shape itself: type=string, format=password, x-cog-secret, writeOnly.
stdout '"api_key":'
stdout '"format":"password"'
stdout '"x-cog-secret":true'

# The bug fix: api_key must be nullable and have an explicit null default.
stdout '"nullable":true'
stdout '"default":null'

# api_key must NOT be in `required`. We list every required field so we
# can pin the exact contents — this keeps the assertion honest even if
# new fields are added later.
stdout '"required":\["prompt","api_key_required","seed"\]'

-- cog.yaml --
build:
  python_version: "3.12"
predict: "predict.py:Predictor"

-- predict.py --
from cog import BasePredictor, Input, Secret


class Predictor(BasePredictor):
    def predict(
        self,
        # Plain required input.
        prompt: str = Input(description="Text prompt"),
        # The bug-fix case: optional credential with an explicit None default.
        api_key: Secret = Input(
            description="Your API key (optional — uses proxy if omitted)",
            default=None,
        ),
        # Regression guard: Secret without a default= kwarg stays required.
        api_key_required: Secret = Input(description="Required API key"),
        # Regression guard: the `seed: int = Input(default=None)` random-seed
        # idiom is unchanged — None on a non-Secret primitive still means
        # "no real default, generate at runtime".
        seed: int = Input(description="Random seed", default=None),
    ) -> str:
        return prompt
