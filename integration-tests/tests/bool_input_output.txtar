# Test bool as a direct run input and output type

# Build the image
cog build -t $TEST_IMAGE

# Bool input and output works via JSON (true -> false)
cog run $TEST_IMAGE --json '{"flag": true}'
stdout '"output": false'

# Bool input and output works via JSON (false -> true)
cog run $TEST_IMAGE --json '{"flag": false}'
stdout '"output": true'

-- cog.yaml --
build:
  python_version: "3.12"
run: "run.py:Runner"

-- run.py --
from cog import BaseRunner


class Runner(BaseRunner):
    def run(self, flag: bool) -> bool:
        return not flag
