# Test ConcatenateIterator[str] as run output type
#
# ConcatenateIterator is the primary streaming text output type for LLMs.
# cog run renders each yielded token as an array element.

# Build the image
cog build -t $TEST_IMAGE

# Streaming output yields individual tokens
cog run $TEST_IMAGE -i prompt=hello
stdout '"hello"'
stdout '" world"'
stdout '" !"'

-- cog.yaml --
build:
  python_version: "3.12"
run: "run.py:Runner"

-- run.py --
from cog import BaseRunner, ConcatenateIterator


class Runner(BaseRunner):
    def run(self, prompt: str) -> ConcatenateIterator[str]:
        for token in [prompt, " world", " !"]:
            yield token
