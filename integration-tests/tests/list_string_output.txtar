# Test list[str] as run output type

# Build the image
cog build -t $TEST_IMAGE

# List output returns items
cog run $TEST_IMAGE -i text='hello world foo'
stdout 'hello'
stdout 'world'
stdout 'foo'

-- cog.yaml --
build:
  python_version: "3.12"
run: "run.py:Runner"

-- run.py --
from cog import BaseRunner


class Runner(BaseRunner):
    def run(self, text: str) -> list[str]:
        return text.split()
