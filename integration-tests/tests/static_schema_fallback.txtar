# Test that when static schema generation is opted in but encounters an
# unresolvable output type, the build falls back to legacy runtime schema
# generation instead of failing.
#
# The predictor returns numpy.ndarray, which the static parser cannot resolve
# (numpy is in the known-external module list). The static parser emits
# ErrUnresolvableType, and build.go catches it and falls through to the
# legacy Docker-based schema generation path.

# Opt in to static schema generation
env COG_STATIC_SCHEMA=1

# Build should succeed — static fails, legacy takes over
cog build -t $TEST_IMAGE
stderr 'Static schema generation failed'
stderr 'Falling back to legacy runtime schema generation'

# Predict should still work end-to-end via the legacy schema
cog predict $TEST_IMAGE -i prompt=hello
stdout 'hello world'

-- cog.yaml --
build:
  python_version: "3.12"
predict: "predict.py:Predictor"

-- predict.py --
from cog import BasePredictor


class MyOutput:
    """A plain class (not BaseModel) that the static parser cannot resolve."""
    def __init__(self, text: str) -> None:
        self.text = text

    def __str__(self) -> str:
        return self.text


class Predictor(BasePredictor):
    def predict(self, prompt: str) -> MyOutput:
        return MyOutput(text=prompt + " world")
