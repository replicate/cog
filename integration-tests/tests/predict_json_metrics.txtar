# Test that custom metrics appear in `cog predict --json` output.
#
# This verifies the full end-to-end path: Python record_metric() ->
# coglet HTTP response -> Go CLI JSON deserialization -> JSON output.
#
# Regression test: the Go Response struct previously lacked a Metrics
# field, so custom metrics were silently dropped during JSON decoding.

cog build -t $TEST_IMAGE
cog predict $TEST_IMAGE --json '{"prompt": "hello"}'
stdout '"status": "succeeded"'
stdout '"token_count": 10'
stdout '"temperature": 0.7'
stdout '"predict_time"'

-- cog.yaml --
build:
  python_version: "3.12"
predict: "predict.py:Predictor"

-- predict.py --
from cog import BasePredictor, current_scope


class Predictor(BasePredictor):
    def predict(self, prompt: str = "hello") -> str:
        scope = current_scope()
        scope.record_metric("token_count", 10)
        scope.record_metric("temperature", 0.7)
        return "world"
