# Exercise the full `cog push` bundle path with v1 managed weights:
# cog.yaml weights -> implicit cog weights build -> cog push -> OCI index.
# The pushed artifact is an OCI image index carrying the model image
# manifest plus one weight manifest (application/vnd.cog.weight.v1) per
# cog.yaml entry.

[short] skip 'requires local registry'

registry-start

# Two weight directories. Each holds a single small file; the packer
# emits a bundle layer for all the small files under the default
# threshold so we end up with one layer per weight entry.
mkdir weights-alpha
mkdir weights-beta
exec sh -c 'printf AAAA > weights-alpha/data.bin'
exec sh -c 'printf BBBB > weights-beta/data.bin'

# cog push runs the weight builder implicitly when cog.yaml declares
# weights. Presence of weights: in cog.yaml triggers bundle format.
cog push $TEST_REGISTRY/test/bundle-model:v1

# Image push header, then weight push header — one each.
stderr 'Pushing image '
stderr 'Pushing weights\.\.\.'

# Resolve the pushed ref and verify the top-level index shape.
registry-inspect $TEST_REGISTRY/test/bundle-model:v1
stdout 'application/vnd.oci.image.index.v1\+json'
# v1 annotation namespace (spec §2.3).
stdout 'run.cog.reference.type.*weights'
stdout 'run.cog.weight.name.*alpha'
stdout 'run.cog.weight.name.*beta'

-- cog.yaml --
build:
  python_version: "3.12"
predict: "predict.py:Predictor"
weights:
  - name: alpha
    source: weights-alpha
    target: /src/weights-alpha
  - name: beta
    source: weights-beta
    target: /src/weights-beta

-- predict.py --
from cog import BasePredictor

class Predictor(BasePredictor):
    def predict(self, text: str) -> str:
        return f"processed: {text}"
