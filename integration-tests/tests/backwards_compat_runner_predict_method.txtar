# Test backwards compat: BaseRunner class with predict() method
# A user using the new BaseRunner class but still defining predict()
# instead of run() should still work.

# Build the image
cog build -t $TEST_IMAGE

# Basic prediction works
cog run $TEST_IMAGE -i name=world
stdout 'hello world'

-- cog.yaml --
build:
  python_version: "3.12"
run: "run.py:Runner"

-- run.py --
from cog import BaseRunner, Input

class Runner(BaseRunner):
    def predict(self, name: str = Input(description="Name")) -> str:
        return f"hello {name}"
