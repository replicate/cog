# Test bare dict return type works for run output

# Build the image
cog build -t $TEST_IMAGE

# Run returns a dict
cog run $TEST_IMAGE -i name=alice
stdout '"greeting": "hello alice"'
stdout '"length": 5'

-- cog.yaml --
build:
  python_version: "3.12"
run: "run.py:Runner"

-- run.py --
from cog import BaseRunner


class Runner(BaseRunner):
    def run(self, name: str) -> dict:
        return {"greeting": "hello " + name, "length": len(name)}
