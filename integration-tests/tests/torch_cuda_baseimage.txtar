# Test that cog correctly resolves a cog-base image for Torch 2.0.1+cu118
# and generates the expected Dockerfile with --use-cog-base-image.
#
# Resolves cog-base images from GHCR via COG_REGISTRY_HOST (set in CI).

# Generate Dockerfile — should use cog-base image
cog debug --use-cog-base-image
stdout 'FROM.*cog-base:cuda11.8-python3.10-torch2.0.1'

-- cog.yaml --
build:
  gpu: true
  python_version: "3.10"
  python_packages:
    - "torch==2.0.1+cu118"
run: "run.py:Runner"

-- run.py --
from cog import BaseRunner


class Runner(BaseRunner):
    def run(self, s: str) -> str:
        return "hello " + s
