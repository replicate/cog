# Test Annotated[..., Opaque] through the default static schema path.
#
# This exercises schema generation, Docker label embedding, coglet schema
# loading, JSON input validation, and prediction output serialization for
# opaque object and opaque array shapes.

cog build -t $TEST_IMAGE

exec docker inspect $TEST_IMAGE --format '{{index .Config.Labels "run.cog.openapi_schema"}}'
stdout '"payload":{"title":"Payload","type":"object","x-order":0}'
stdout '"items":{"items":{"type":"object"},"title":"Items","type":"array","x-order":1}'
stdout '"result":{"title":"Result","type":"object"}'
stdout '"results":{"items":{"type":"object"},"title":"Results","type":"array"}'
stdout '"required":\["payload","items"\]'
stdout '"required":\["result","results"\]'

cog predict $TEST_IMAGE --json '{"payload": {"name": "alice", "count": 2}, "items": [{"name": "first"}, {"name": "second"}]}'
stdout '"status": "succeeded"'
stdout '"result": \{'
stdout '"count": 2'
stdout '"name": "alice"'
stdout '"results": \['
stdout '"name": "first"'
stdout '"name": "second"'

-- cog.yaml --
build:
  python_version: "3.12"
predict: "predict.py:Predictor"

-- third_party.py --
class ExternalObject:
    pass

-- predict.py --
from typing import Annotated, List

from cog import BaseModel, BasePredictor, Opaque
from third_party import ExternalObject


class Output(BaseModel):
    result: Annotated[ExternalObject, Opaque]
    results: Annotated[List[ExternalObject], Opaque]


class Predictor(BasePredictor):
    def predict(
        self,
        payload: Annotated[ExternalObject, Opaque],
        items: Annotated[List[ExternalObject], Opaque],
    ) -> Output:
        return Output(result=payload, results=items)
