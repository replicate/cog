# Test that a runner importing the deprecated ExperimentalFeatureWarning
# still builds and runs successfully.

# Build the image
cog build -t $TEST_IMAGE

# Prediction works despite the deprecated import
cog run $TEST_IMAGE -i s=world
stdout 'hello world'

-- cog.yaml --
build:
  python_version: "3.12"
run: "run.py:Runner"

-- run.py --
import warnings
from cog import BaseRunner, ExperimentalFeatureWarning

warnings.filterwarnings("ignore", category=ExperimentalFeatureWarning)

class Runner(BaseRunner):
    def run(self, s: str) -> str:
        return "hello " + s
