# Test that cog doctor succeeds on a valid project with no issues.

cog doctor
stderr 'experimental'
stderr 'no issues found'

-- cog.yaml --
build:
  python_version: "3.12"
run: "run.py:Runner"

-- run.py --
from cog import BaseRunner


class Runner(BaseRunner):
    def run(self, text: str) -> str:
        return "hello " + text
