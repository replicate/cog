grep 'run: "run.py:Runner"' cog.yaml
grep 'class Runner(BaseRunner):' run.py
grep 'def run(' run.py
! test -f predict.py

-- cog.yaml --
build:
  python_version: "3.12"
predict: "predict.py:Predictor"

-- predict.py --
from cog import BasePredictor

class Predictor(BasePredictor):
    def predict(self, s: str) -> str:
        return "hello " + s
