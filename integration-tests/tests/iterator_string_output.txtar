# Test Iterator[str] as run output type
#
# Iterator[str] yields individual string items as an array.

# Build the image
cog build -t $TEST_IMAGE

# Iterator output returns items
cog run $TEST_IMAGE -i count=3
stdout 'item-0'
stdout 'item-1'
stdout 'item-2'

-- cog.yaml --
build:
  python_version: "3.12"
run: "run.py:Runner"

-- run.py --
from typing import Iterator

from cog import BaseRunner


class Runner(BaseRunner):
    def run(self, count: int) -> Iterator[str]:
        for i in range(count):
            yield f"item-{i}"
